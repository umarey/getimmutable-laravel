{
    "name": "getimmutable/laravel",
    "description": "Laravel SDK for the Immutable audit log API.",
    "type": "library",
    "version": "0.1.0",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0"
    },
    "autoload": {
        "psr-4": {
            "GetImmutable\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "GetImmutable\\GetImmutableServiceProvider"
            ],
            "aliases": {
                "AuditLog": "GetImmutable\\AuditLog"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
